{
  "name": "soundwave",
  "version": "0.2.22",
  "description": "Modern SoundCloud desktop client with custom themes and Discord RPC",
  "main": "dist-electron/main.js",
  "author": "you",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build": "tsc -p electron/tsconfig.json && vite build && electron-builder",
    "build:win": "tsc -p electron/tsconfig.json && vite build && electron-builder --win",
    "build:mac": "tsc -p electron/tsconfig.json && vite build && electron-builder --mac",
    "build:linux": "tsc -p electron/tsconfig.json && vite build && electron-builder --linux",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.2.0",
    "https-proxy-agent": "^9.0.0",
    "lucide-react": "^0.383.0",
    "peerjs": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.8",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.soundwave.app",
    "productName": "Soundwave",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "sign": null,
      "signAndEditExecutable": true,
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Audio"
    },
    "publish": {
      "provider": "github",
      "owner": "mimimima592",
      "repo": "soundwave",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  }
}